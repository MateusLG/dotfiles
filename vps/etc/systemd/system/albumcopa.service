[Unit]
Description=album-copa / FALTINHA (FastAPI + Vite)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=albumcopa
WorkingDirectory=/srv/albumcopa/backend
ExecStart=/srv/albumcopa/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
