[Unit]
Description=turmasunb (FastAPI/uvicorn)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=mateus
WorkingDirectory=/home/mateus/apps/turmasunb
ExecStart=/home/mateus/apps/turmasunb/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
